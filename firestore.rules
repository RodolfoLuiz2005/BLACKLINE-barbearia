rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: agendamentos
    // Document ID: random appointment id, equal to field id.
    // Contains client PII and is readable only by admins.
    // Fields:
    //   - id: string (required, immutable client/admin identity)
    //   - codigo: string (required, BLK-[A-Z2-9]{6})
    //   - consultaId: string (required, sha256 hex of WhatsApp+codigo)
    //   - nome: string (required, 2..80) - PII
    //   - telefone: string (required, 11 digits) - PII
    //   - servico/servicoId/profissionalId/profissionalNome: string
    //   - data: string YYYY-MM-DD
    //   - horario: string HH:MM
    //   - duracaoMinutos: number/int 1..90
    //   - preco: number 0..10000
    //   - observacoes: optional string 0..300
    //   - status: pendente|confirmado|em_atendimento|concluido|cancelado
    //   - slotIds: list of deterministic ocupacaoHorarios ids for active bookings
    //   - criadoEm/atualizadoEm: ISO-like strings
    //
    // Collection: consultasAgendamento
    // Document ID: consultaId. Same fields as agendamentos. Public clients may
    // get one exact document only when they know WhatsApp+codigo and can compute
    // the hash in the app. Listing is admin-only.
    //
    // Collection: ocupacaoHorarios
    // Document ID: profissionalId_YYYY-MM-DD_HH:MM.
    // Public clients may get individual slot documents to render availability.
    // Slot documents contain no client PII and cannot be listed publicly.
    //
    // Catalog collections are public-read and admin-write. Do not store PII in
    // public catalog/config documents.
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerifiedOwnerEmail() {
      return isAuthenticated()
        && request.auth.token.email == 'rodolfoluiz09082020@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated()
        && (
          request.auth.uid == 'HLaZh9fIaPWjIkHgV9koGGyrEJx2'
          || request.auth.token.admin == true
          || isVerifiedOwnerEmail()
        );
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    function validString(data, field, minLen, maxLen) {
      return data[field] is string
        && data[field].size() >= minLen
        && data[field].size() <= maxLen;
    }

    function validOptionalString(data, field, maxLen) {
      return !(field in data)
        || (data[field] is string && data[field].size() <= maxLen);
    }

    function validNumber(data, field, minValue, maxValue) {
      return (data[field] is int || data[field] is float)
        && data[field] >= minValue
        && data[field] <= maxValue;
    }

    function isValidDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidTime(value) {
      return value is string && value.matches('^\\d{2}:\\d{2}$');
    }

    function isValidPhone(value) {
      return value is string && value.matches('^\\d{11}$');
    }

    function isValidLookupId(value) {
      return value is string && value.matches('^[a-f0-9]{64}$');
    }

    function isValidStatus(value) {
      return value in ['pendente', 'confirmado', 'em_atendimento', 'concluido', 'cancelado'];
    }

    function isBlockingStatus(value) {
      return value in ['pendente', 'confirmado', 'em_atendimento'];
    }

    function isClientMutableStatus(value) {
      return value in ['pendente', 'confirmado'];
    }

    function isValidSlotId(value) {
      return value is string
        && value.matches('^[A-Za-z0-9_-]{1,80}_\\d{4}-\\d{2}-\\d{2}_\\d{2}:\\d{2}$');
    }

    function appointmentFields() {
      return [
        'id',
        'codigo',
        'consultaId',
        'nome',
        'telefone',
        'servico',
        'servicoId',
        'profissionalId',
        'profissionalNome',
        'data',
        'horario',
        'duracaoMinutos',
        'preco',
        'observacoes',
        'status',
        'slotIds',
        'criadoEm',
        'atualizadoEm'
      ];
    }

    function activeSlotCountMatchesDuration(data) {
      return (data.duracaoMinutos <= 30 && data.slotIds.size() == 1)
        || (data.duracaoMinutos > 30 && data.duracaoMinutos <= 60 && data.slotIds.size() == 2)
        || (data.duracaoMinutos > 60 && data.duracaoMinutos <= 90 && data.slotIds.size() == 3);
    }

    function slotIdsAreValid(data) {
      return data.slotIds is list
        && (
          (!isBlockingStatus(data.status) && data.slotIds.size() == 0)
          || (
            isBlockingStatus(data.status)
            && data.slotIds.size() >= 1
            && data.slotIds.size() <= 3
            && activeSlotCountMatchesDuration(data)
            && isValidSlotId(data.slotIds[0])
            && data.slotIds[0] == data.profissionalId + '_' + data.data + '_' + data.horario
            && (data.slotIds.size() < 2 || (isValidSlotId(data.slotIds[1]) && data.slotIds[1] != data.slotIds[0]))
            && (data.slotIds.size() < 3 || (isValidSlotId(data.slotIds[2]) && data.slotIds[2] != data.slotIds[0] && data.slotIds[2] != data.slotIds[1]))
          )
        );
    }

    function isValidAppointmentData(data) {
      return hasOnlyAllowedFields(data, appointmentFields())
        && hasRequiredFields(data, ['id', 'codigo', 'consultaId', 'nome', 'telefone', 'servico', 'servicoId', 'profissionalId', 'profissionalNome', 'data', 'horario', 'duracaoMinutos', 'preco', 'status', 'slotIds', 'criadoEm', 'atualizadoEm'])
        && validString(data, 'id', 1, 80)
        && validString(data, 'codigo', 10, 10)
        && data.codigo.matches('^BLK-[A-Z2-9]{6}$')
        && isValidLookupId(data.consultaId)
        && validString(data, 'nome', 2, 80)
        && isValidPhone(data.telefone)
        && validString(data, 'servico', 1, 80)
        && validString(data, 'servicoId', 1, 80)
        && validString(data, 'profissionalId', 1, 80)
        && validString(data, 'profissionalNome', 1, 80)
        && isValidDate(data.data)
        && isValidTime(data.horario)
        && validNumber(data, 'duracaoMinutos', 1, 90)
        && validNumber(data, 'preco', 0, 10000)
        && validOptionalString(data, 'observacoes', 300)
        && isValidStatus(data.status)
        && slotIdsAreValid(data)
        && validString(data, 'criadoEm', 10, 40)
        && validString(data, 'atualizadoEm', 10, 40);
    }

    function slotBelongsToAppointment(data, slotId) {
      return data.slotIds is list
        && (
          (data.slotIds.size() > 0 && data.slotIds[0] == slotId)
          || (data.slotIds.size() > 1 && data.slotIds[1] == slotId)
          || (data.slotIds.size() > 2 && data.slotIds[2] == slotId)
        );
    }

    function clientImmutableFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'id',
        'codigo',
        'consultaId',
        'nome',
        'telefone',
        'servico',
        'servicoId',
        'duracaoMinutos',
        'preco',
        'observacoes',
        'criadoEm'
      ]);
    }

    function clientCancellation() {
      return isClientMutableStatus(resource.data.status)
        && request.resource.data.status == 'cancelado'
        && request.resource.data.slotIds.size() == 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'slotIds', 'atualizadoEm']);
    }

    function clientReschedule() {
      return isClientMutableStatus(resource.data.status)
        && request.resource.data.status == 'pendente'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profissionalId', 'profissionalNome', 'data', 'horario', 'status', 'slotIds', 'atualizadoEm']);
    }

    function clientAppointmentUpdateIsValid(appointmentId) {
      return isValidAppointmentData(request.resource.data)
        && request.resource.data.id == appointmentId
        && clientImmutableFieldsUnchanged()
        && (clientCancellation() || clientReschedule());
    }

    function publicCreateIsValid(appointmentId) {
      return request.resource.data.id == appointmentId
        && request.resource.data.status == 'pendente'
        && isValidAppointmentData(request.resource.data);
    }

    function isValidSlotData(data, slotId) {
      return data.keys().hasOnly(['agendamentoId', 'profissionalId', 'data', 'horario', 'status', 'criadoEm', 'atualizadoEm'])
        && data.keys().hasAll(['agendamentoId', 'profissionalId', 'data', 'horario', 'status', 'criadoEm', 'atualizadoEm'])
        && validString(data, 'agendamentoId', 1, 80)
        && validString(data, 'profissionalId', 1, 80)
        && isValidDate(data.data)
        && isValidTime(data.horario)
        && isValidStatus(data.status)
        && validString(data, 'criadoEm', 10, 40)
        && validString(data, 'atualizadoEm', 10, 40)
        && slotId == data.profissionalId + '_' + data.data + '_' + data.horario;
    }

    function publicSlotCreateIsValid(slotId) {
      return isValidSlotData(request.resource.data, slotId)
        && isBlockingStatus(request.resource.data.status);
    }

    function slotDeleteIsLinked(slotId) {
      let appointment = getAfter(/databases/$(database)/documents/agendamentos/$(resource.data.agendamentoId)).data;
      return resource.data.agendamentoId is string
        && (
          !isBlockingStatus(appointment.status)
          || !slotBelongsToAppointment(appointment, slotId)
        );
    }

    function catalogFields() {
      return ['ativo', 'criadoEm', 'descricao', 'duracao', 'especialidade', 'foto', 'horariosAtendimento', 'imagemUrl', 'nome', 'ordem', 'preco', 'titulo', 'atualizadoEm', 'beneficios', 'categoria', 'endereco', 'google', 'horario', 'mapa', 'redesSociais', 'telefone', 'whatsapp'];
    }

    function isValidCatalogDocument() {
      return request.resource.data.keys().hasOnly(catalogFields());
    }

    match /servicos/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogDocument();
      allow delete: if isAdmin();
    }

    match /profissionais/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogDocument();
      allow delete: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogDocument();
      allow delete: if isAdmin();
    }

    match /galeria/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogDocument();
      allow delete: if isAdmin();
    }

    match /planos/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCatalogDocument();
      allow delete: if isAdmin();
    }

    match /agendamentos/{appointmentId} {
      allow read: if isAdmin();
      allow create: if publicCreateIsValid(appointmentId);
      allow update: if (isAdmin() && isValidAppointmentData(request.resource.data))
        || clientAppointmentUpdateIsValid(appointmentId);
      allow delete: if isAdmin();
    }

    match /consultasAgendamento/{lookupId} {
      allow get: if isValidLookupId(lookupId);
      allow list: if isAdmin();
      allow create: if lookupId == request.resource.data.consultaId
        && isValidAppointmentData(request.resource.data)
        && request.resource.data.status == 'pendente';
      allow update: if (isAdmin() && isValidAppointmentData(request.resource.data))
        || (
          lookupId == resource.data.consultaId
          && lookupId == request.resource.data.consultaId
          && clientImmutableFieldsUnchanged()
          && (clientCancellation() || clientReschedule())
        );
      allow delete: if isAdmin();
    }

    match /ocupacaoHorarios/{slotId} {
      allow get: if isValidSlotId(slotId);
      allow list: if isAdmin();
      allow create: if isAdmin() || publicSlotCreateIsValid(slotId);
      allow update: if isAdmin() && isValidSlotData(request.resource.data, slotId);
      allow delete: if isAdmin() || slotDeleteIsLinked(slotId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
