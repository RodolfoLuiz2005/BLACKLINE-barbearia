# Backend
PORT=3001
DB_PATH=/app/data/agendamentos.json
NODE_ENV=development
ADMIN_PASSWORD=
TOKEN_SECRET=

# Frontend Firebase
# Valores VITE_ sao publicados no bundle final. Configure restricoes da chave no Google Cloud
# e regras de seguranca no Firebase; nao coloque valores reais neste arquivo.
# Nunca coloque service account, private key, token secreto ou credencial sensivel em VITE_.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Frontend (nginx)
# NGINX_PORT=80